{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sol.local/schemas/style-kit/v1/evaluation-event.schema.json",
  "title": "Sol Creative Style Kit Evaluation Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "owner_id",
    "consent_refs",
    "run_id",
    "evaluation_state",
    "was_blinded",
    "presented_variant_order",
    "selected_variant_id",
    "choice",
    "feels_like_me",
    "usefulness",
    "labels",
    "correction",
    "affected_guidance_refs",
    "provenance",
    "record_state",
    "export_state",
    "created_at",
    "updated_at",
    "deleted_at"
  ],
  "properties": {
    "schema_version": {"const": "sol.style-kit.evaluation-event.v1"},
    "id": {"type": "string", "pattern": "^eval_[a-z0-9][a-z0-9._-]{2,194}$"},
    "owner_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,199}$"},
    "consent_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^consent_[a-z0-9][a-z0-9._-]{2,191}$"}
    },
    "run_id": {"type": "string", "pattern": "^run_[a-z0-9][a-z0-9._-]{2,195}$"},
    "evaluation_state": {"enum": ["choice_recorded", "revealed", "deleted"]},
    "was_blinded": {"const": true},
    "presented_variant_order": {
      "type": "array",
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^variant_[a-z0-9][a-z0-9._-]{2,191}$"}
    },
    "selected_variant_id": {
      "type": ["string", "null"],
      "pattern": "^variant_[a-z0-9][a-z0-9._-]{2,191}$"
    },
    "choice": {"enum": ["personalized", "generic", "tie", "cannot_judge", null]},
    "feels_like_me": {"type": ["integer", "null"], "minimum": 1, "maximum": 5},
    "usefulness": {"type": ["integer", "null"], "minimum": 1, "maximum": 5},
    "labels": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["accurate", "useful", "too_strong", "too_generic", "wrong"]}
    },
    "correction": {"type": ["string", "null"], "maxLength": 2000},
    "affected_guidance_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^guide_[a-z0-9][a-z0-9._-]{2,193}$"}
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recorded_by",
        "evaluation_contract_version",
        "choice_recorded_at",
        "identity_revealed_at",
        "revealed_after_choice"
      ],
      "properties": {
        "recorded_by": {"const": "user"},
        "evaluation_contract_version": {"const": 1},
        "choice_recorded_at": {"type": ["string", "null"], "format": "date-time"},
        "identity_revealed_at": {"type": ["string", "null"], "format": "date-time"},
        "revealed_after_choice": {"type": "boolean"}
      }
    },
    "record_state": {"enum": ["active", "deleted"]},
    "export_state": {"enum": ["exportable", "deleted"]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "deleted_at": {"type": ["string", "null"], "format": "date-time"}
  }
}
